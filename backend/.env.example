APP_NAME=EdgePilot Backend
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://edgepilot:edgepilot@localhost:5432/edgepilot
REDIS_URL=redis://localhost:6379/0
SSE_HEARTBEAT_SECONDS=15
CORS_ALLOWED_ORIGINS=http://localhost:3000

AUTH_ENABLED=false
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URL=
AUTH_ALGORITHMS=RS256
AUTH_ACCOUNT_CLAIM=https://edgepilot/account_id
AUTH_ROLE_CLAIM=https://edgepilot/role
AUTH_DEFAULT_ROLE=owner

POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
INGESTION_ADMIN_TOKEN=
JQUANTS_EMAIL=
JQUANTS_PASSWORD=
OPENAI_API_KEY=
