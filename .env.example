# ---------- App ----------
APP_NAME=EdgePilot
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---------- Database ----------
POSTGRES_DB=edgepilot
POSTGRES_USER=edgepilot
POSTGRES_PASSWORD=edgepilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
TIMESCALE_ENABLED=true
DATABASE_URL=postgresql://edgepilot:edgepilot@localhost:5432/edgepilot

# ---------- Cache / Realtime ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
SSE_HEARTBEAT_SECONDS=15

# ---------- Market Data Providers ----------
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
JQUANTS_EMAIL=
JQUANTS_PASSWORD=
IBKR_HOST=
IBKR_PORT=

# ---------- AI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
